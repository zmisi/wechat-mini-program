.page {
  min-height: 100vh;
  background: #f5f6fa;
}

.list {
  height: 100vh;
  padding: 16rpx;
  box-sizing: border-box;
}

.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-main .name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.item-main .meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.empty {
  padding: 80rpx;
  text-align: center;
  color: #64748b;
}
