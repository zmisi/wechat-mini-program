.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #f5f6fa;
}

.card {
  width: 100%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.title {
  text-align: center;
  font-size: 42rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}

.consent-box {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.consent-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 12rpx;
}

.consent-text,
.consent-item {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.consent-item {
  padding-left: 8rpx;
}

.login-btn {
  width: 100%;
}
