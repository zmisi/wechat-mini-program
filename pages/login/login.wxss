.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #f5f6fa;
}

.card {
  width: 100%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.title {
  text-align: center;
  font-size: 42rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}

.consent-box {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.consent-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 12rpx;
}

.consent-text,
.consent-item {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.consent-item {
  padding-left: 8rpx;
}

.login-btn {
  width: 100%;
}

.consent-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.consent-panel {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.consent-panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2d3d;
  text-align: center;
  margin-bottom: 20rpx;
}

.consent-panel-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.consent-panel-link {
  display: block;
  font-size: 26rpx;
  color: #07c160;
  margin-bottom: 28rpx;
}

.consent-agree-btn {
  width: 100%;
  margin-bottom: 16rpx;
}

.consent-skip-btn {
  width: 100%;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  border: none;
}

.consent-skip-btn::after {
  border: none;
}
