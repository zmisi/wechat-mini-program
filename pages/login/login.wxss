.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.card {
  width: 100%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.title {
  text-align: center;
  font-size: 42rpx;
  font-weight: 600;
}

.subtitle {
  text-align: center;
  margin-top: 24rpx;
  color: #667085;
  font-size: 28rpx;
  margin-bottom: 36rpx;
}

.login-btn {
  width: 100%;
}
