.chat-page {
  height: calc(100vh - 100rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #f5f6fa;
  overflow: hidden;
  box-sizing: border-box;
}

.top-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
}

.top-spacer {
  width: 80rpx;
  flex-shrink: 0;
}

.top-center {
  flex: 1;
  text-align: center;
  min-width: 0;
  padding: 0 8rpx;
}

.top-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-meta {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
  line-height: 1.4;
  word-break: break-all;
}

.top-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 4rpx;
}

.top-btn {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  color: #64748b;
}

.top-btn.primary {
  color: #07c160;
  font-weight: 600;
}

.center-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: calc(33vh - 80rpx) 32rpx 40rpx;
  box-sizing: border-box;
  min-height: 0;
}

.empty-hint {
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.empty-desc {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
}

.chat-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.messages {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 82%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.assistant .bubble.has-table {
  max-width: 94%;
}

.user .bubble {
  background: #07c160;
  color: #ffffff;
}

.assistant .bubble {
  background: #ffffff;
  color: #1f2d3d;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.loading-bubble {
  opacity: 0.85;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.data-table-wrap {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #eef2f7;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.table-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
}

.table-title.tier-reach {
  color: #c2410c;
}

.table-title.tier-steady {
  color: #0369a1;
}

.table-title.tier-safe {
  color: #15803d;
}

.table-h-scroll {
  width: 100%;
  margin-top: 4rpx;
}

.table-body-scroll {
  display: block;
}

.data-table {
  display: block;
}

.table-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
}

.table-header {
  background: #e2e8f0;
  border-radius: 8rpx 8rpx 0 0;
  flex-shrink: 0;
  z-index: 2;
}

.table-body-scroll .table-row {
  border-bottom: 1rpx solid #e2e8f0;
  background: #eef2f7;
}

.table-header .table-cell-text {
  font-weight: 600;
  color: #334155;
}

.table-cell {
  flex: 0 0 auto;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.table-cell-text.align-left {
  text-align: left;
}

.table-cell-text.align-center {
  text-align: center;
}

.table-cell-text {
  display: block;
  width: 100%;
  font-size: 22rpx;
  line-height: 1.45;
  color: #1f2d3d;
}

.table-cell-text.nowrap {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.table-cell-text.wrap {
  white-space: normal;
  word-break: break-all;
}

.composer-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 9998;
  padding: 8rpx 24rpx 4rpx;
  background: #f5f6fa;
  box-sizing: border-box;
}

.composer-bottom-bar .composer-center-wrap {
  width: 100%;
}

.composer-center-wrap {
  width: 90vw;
  margin: 0 auto;
}

.composer-center-input {
  display: flex;
  align-items: flex-end;
  background: #ffffff;
  border: 1px solid #d0d5dd;
  border-radius: 40rpx;
  padding: 10rpx 10rpx 10rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.input-center {
  flex: 1;
  min-height: 72rpx;
  max-height: 240rpx;
  padding: 14rpx 12rpx 14rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  background: transparent;
  box-sizing: border-box;
}

.send-icon-btn {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  margin-left: 8rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-icon-btn.disabled {
  opacity: 0.35;
}

.send-icon-arrow {
  width: 22rpx;
  height: 22rpx;
  border-top: 4rpx solid #ffffff;
  border-right: 4rpx solid #ffffff;
  transform: rotate(-45deg) translate(-2rpx, 2rpx);
}

.send-icon-loading {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

