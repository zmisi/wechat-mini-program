<template name="chatComposer">
  <view class="composer-center-wrap">
    <view class="composer-center-input">
      <textarea
        class="input-center"
        placeholder="{{placeholder}}"
        value="{{inputText}}"
        bindinput="onInput"
        disabled="{{loading}}"
        auto-height
        maxlength="-1"
        show-confirm-bar="{{false}}"
      />
      <view
        class="send-icon-btn {{loading || !inputText ? 'disabled' : ''}}"
        bindtap="sendMessage"
      >
        <view wx:if="{{loading}}" class="send-icon-loading"></view>
        <view wx:else class="send-icon-arrow"></view>
      </view>
    </view>
  </view>
</template>

<view class="chat-page">
  <view class="top-bar">
    <view class="top-spacer"></view>
    <view class="top-center">
      <text class="top-title">{{chatTitle}}</text>
      <text wx:if="{{roleLabel}}" class="top-meta">{{roleLabel}}{{quotaHint}}</text>
    </view>
    <view class="top-actions">
      <view wx:if="{{isAdmin}}" class="top-btn" bindtap="openAdmin">管理</view>
    </view>
  </view>

  <!-- 无消息：输入框居中 -->
  <view wx:if="{{!hasMessages}}" class="center-stage">
    <view class="empty-hint">
      <text class="empty-title">个人志愿随手查</text>
      <text class="empty-desc">输入问题开始对话，例如：安徽物理类630分2025普通批可报哪些专业？</text>
    </view>
    <template
      is="chatComposer"
      data="{{placeholder: '输入升学问题…', inputText: inputText, loading: loading}}"
    />
  </view>

  <!-- 有消息：消息区可滚动 + 底部输入 -->
  <view wx:else class="chat-stage">
    <scroll-view
      class="messages"
      scroll-y
      enhanced
      show-scrollbar
      scroll-with-animation
      scroll-into-view="{{scrollIntoView}}"
      style="height: {{scrollHeight}}px;"
    >
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="msg-row {{item.role}}"
      >
        <view class="bubble {{item.hasTables ? 'has-table' : ''}}">
          <text wx:if="{{item.text}}" class="bubble-text" user-select>{{item.text}}</text>
          <view
            wx:for="{{item.tables}}"
            wx:for-item="table"
            wx:key="id"
            class="data-table-wrap"
          >
            <text wx:if="{{table.title}}" class="table-title {{table.tierClass}}">{{table.title}}</text>
            <view wx:if="{{table.useGroups}}" class="school-group-list">
              <view
                wx:for="{{table.groups}}"
                wx:for-item="group"
                wx:key="id"
                class="school-group"
              >
                <view
                  class="school-header"
                  bindtap="toggleSchoolExpand"
                  data-msg-id="{{item.id}}"
                  data-table-id="{{table.id}}"
                  data-group-id="{{group.id}}"
                >
                  <view class="school-header-main">
                    <text class="school-name">{{group.universityName}}</text>
                    <text class="school-meta">{{group.summary}}</text>
                  </view>
                  <text class="school-chevron {{group.expanded ? 'expanded' : ''}}">›</text>
                </view>
                <view wx:if="{{group.expanded}}" class="major-table-wrap">
                  <scroll-view scroll-x enhanced show-scrollbar class="table-h-scroll">
                    <view class="data-table" style="width: {{group.tableWidthRpx}}rpx;">
                      <view class="table-row table-header">
                        <view
                          wx:for="{{group.columns}}"
                          wx:for-item="col"
                          wx:key="key"
                          class="table-cell"
                          style="width: {{col.widthRpx}}rpx;"
                        >
                          <text class="table-cell-text align-{{col.align}} {{col.wrap ? 'wrap' : 'nowrap'}}">{{col.label}}</text>
                        </view>
                      </view>
                      <scroll-view
                        scroll-y
                        enhanced
                        show-scrollbar
                        class="table-body-scroll"
                        style="height: {{group.bodyScrollHeightRpx}}rpx; width: {{group.tableWidthRpx}}rpx;"
                      >
                        <view
                          wx:for="{{group.rows}}"
                          wx:for-item="row"
                          wx:key="id"
                          class="table-row"
                        >
                          <view
                            wx:for="{{row.cells}}"
                            wx:for-item="cell"
                            wx:for-index="cellIndex"
                            wx:key="cellIndex"
                            class="table-cell"
                            style="width: {{cell.widthRpx}}rpx;"
                          >
                            <text class="table-cell-text align-{{cell.align}} {{cell.wrap ? 'wrap' : 'nowrap'}}">{{cell.value}}</text>
                          </view>
                        </view>
                      </scroll-view>
                    </view>
                  </scroll-view>
                </view>
              </view>
            </view>
            <view wx:else class="table-empty-hint">暂无匹配专业</view>
          </view>
        </view>
      </view>

      <view wx:if="{{loading}}" class="msg-row assistant" id="msg-loading">
        <view class="bubble loading-bubble">
          <text class="bubble-text">正在思考，请稍候…</text>
        </view>
      </view>
    </scroll-view>

    <view class="composer-bottom-bar" style="bottom: {{composerBottom}}px;">
      <template
        is="chatComposer"
        data="{{placeholder: '继续追问…', inputText: inputText, loading: loading}}"
      />
    </view>
  </view>
</view>
