.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.setup-banner {
  background: #ecfdf5;
  border: 1px solid #a7f3d0;
  color: #047857;
  font-size: 26rpx;
  line-height: 1.5;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.profile-hint {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.profile-edit-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.avatar-picker {
  margin: 0;
  padding: 0;
  width: 120rpx;
  height: 120rpx;
  border: none;
  border-radius: 50%;
  background: transparent;
  line-height: 1;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-picker::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e2e8f0;
  display: block;
}

.edit-fields {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.nickname-input {
  width: 100%;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2d3d;
  background: #ffffff;
  box-sizing: border-box;
}

.save-profile-btn {
  margin: 16rpx 0 0;
}

.readonly-meta .meta {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
}

.meta {
  display: block;
  font-size: 26rpx;
  color: #64748b;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.label {
  color: #64748b;
  flex-shrink: 0;
}

.value {
  color: #1f2d3d;
  text-align: right;
}

.unlimited {
  color: #07c160;
}

.quota-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.upgrade-tip {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #fff7ed;
  border-radius: 12rpx;
  color: #c2410c;
  font-size: 24rpx;
  line-height: 1.5;
}

.admin-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-link {
  font-size: 30rpx;
  color: #1f2d3d;
}

.admin-arrow {
  font-size: 36rpx;
  color: #94a3b8;
}

.logout-btn {
  margin-top: 8rpx;
  background: #ffffff;
  color: #e11d48;
  border: 1px solid #fecdd3;
}
