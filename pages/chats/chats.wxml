<view class="page page-with-tabbar">
  <view class="header">
    <text class="header-title">会话</text>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中…</view>
  <view wx:elif="{{conversations.length === 0}}" class="empty">暂无会话，点底部「新对话」开始</view>

  <scroll-view wx:else scroll-y class="list" enhanced show-scrollbar>
    <view
      wx:for="{{conversations}}"
      wx:key="id"
      class="item"
      data-id="{{item.id}}"
      data-title="{{item.title}}"
      bindtap="openChat"
      bindlongpress="showActions"
    >
      <view class="item-main">
        <text class="item-title">{{item.title}}</text>
        <text class="item-time">{{item.updatedAt}}</text>
      </view>
      <view
        class="item-more"
        data-id="{{item.id}}"
        data-title="{{item.title}}"
        catchtap="showActions"
      >
        ···
      </view>
    </view>
  </scroll-view>

  <view class="footer-tip">长按或点击 ··· 可重命名 / 归档 / 删除</view>
</view>
