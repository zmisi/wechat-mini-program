.page {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
}

.new-btn {
  margin: 0;
}

.list {
  flex: 1;
  height: calc(100vh - 280rpx - env(safe-area-inset-bottom));
  padding: 16rpx 0;
  box-sizing: border-box;
}

.item {
  display: flex;
  align-items: center;
  margin: 0 20rpx 16rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: #1f2d3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.item-more {
  flex-shrink: 0;
  padding: 0 12rpx;
  font-size: 34rpx;
  color: #64748b;
}

.empty {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
}

.footer-tip {
  padding: 16rpx 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
}
